-- Creates a BillboardGui set of ESP elements for a character
local function CreateEspForPlayer(OtherPlayer)
	local Char = OtherPlayer.Character
	if not Char then return end

	local Root = Char:FindFirstChild("HumanoidRootPart")
	if not Root then return end

	-- Main billboard (name + hitbox container)
	local Billboard = Instance.new("BillboardGui")
	Billboard.Adornee = Root
	Billboard.Size = UDim2.new(0,60,0,80)
	Billboard.StudsOffset = Vector3.new(0,3,0)
	Billboard.AlwaysOnTop = true
	Billboard.Enabled = false
	Billboard.Parent = ScreenGui

	-- Name label
	local NameLabel = Instance.new("TextLabel")
	NameLabel.Size = UDim2.new(1,0,0,16)
	NameLabel.Position = UDim2.new(0,0,0,0)
	NameLabel.BackgroundTransparency = 1
	NameLabel.Text = OtherPlayer.Name
	NameLabel.TextColor3 = Color3.fromRGB(255,255,255)
	NameLabel.Font = Enum.Font.GothamBold
	NameLabel.TextSize = 11
	NameLabel.Parent = Billboard

	-- Hitbox (white outline box around player)
	local HitboxGui = Instance.new("BillboardGui")
	HitboxGui.Adornee = Root
	HitboxGui.Size = UDim2.new(0,46,0,70)
	HitboxGui.StudsOffset = Vector3.new(0,1,0)
	HitboxGui.AlwaysOnTop = true
	HitboxGui.Enabled = false
	HitboxGui.Parent = ScreenGui

	local HitboxFrame = Instance.new("Frame")
	HitboxFrame.Size = UDim2.new(1,0,1,0)
	HitboxFrame.BackgroundTransparency = 1
	HitboxFrame.Parent = HitboxGui

	local HitboxStroke = Instance.new("UIStroke")
	HitboxStroke.Color = Color3.fromRGB(255,255,255)
	HitboxStroke.Thickness = 1.2
	HitboxStroke.Parent = HitboxFrame

	-- Health bar (left side of hitbox)
	local HealthBG = Instance.new("BillboardGui")
	HealthBG.Adornee = Root
	HealthBG.Size = UDim2.new(0,4,0,70)
	HealthBG.StudsOffset = Vector3.new(-2.8,1,0)
	HealthBG.AlwaysOnTop = true
	HealthBG.Enabled = false
	HealthBG.Parent = ScreenGui

	local HealthTrack = Instance.new("Frame")
	HealthTrack.Size = UDim2.new(1,0,1,0)
	HealthTrack.BackgroundColor3 = Color3.fromRGB(50,50,50)
	HealthTrack.BorderSizePixel = 0
	HealthTrack.Parent = HealthBG

	local HealthFill = Instance.new("Frame")
	HealthFill.Size = UDim2.new(1,0,1,0) -- updated each frame
	HealthFill.AnchorPoint = Vector2.new(0,1)
	HealthFill.Position = UDim2.new(0,0,1,0)
	HealthFill.BackgroundColor3 = Color3.fromRGB(80,220,80)
	HealthFill.BorderSizePixel = 0
	HealthFill.Parent = HealthTrack

	EspObjects[OtherPlayer.UserId] = {
		Billboard  = Billboard,
		Hitbox     = HitboxGui,
		HealthBG   = HealthBG,
		HealthFill = HealthFill,
		Character  = Char,
		HumanoidRef = Char:FindFirstChildOfClass("Humanoid"),
	}
end

local function RemoveEspForPlayer(OtherPlayer)
	local obj = EspObjects[OtherPlayer.UserId]
	if obj then
		if obj.Billboard then obj.Billboard:Destroy() end
		if obj.Hitbox    then obj.Hitbox:Destroy()    end
		if obj.HealthBG  then obj.HealthBG:Destroy()  end
		EspObjects[OtherPlayer.UserId] = nil
	end
end

-- Build ESP for existing players and hook new ones
for _, p in ipairs(Players:GetPlayers()) do
	if p ~= Player then CreateEspForPlayer(p) end
end

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function()
		task.wait(0.5)
		RemoveEspForPlayer(p)
		CreateEspForPlayer(p)
	end)
	CreateEspForPlayer(p)
end)

Players.PlayerRemoving:Connect(RemoveEspForPlayer)

-- Rebuild ESP when a player's character respawns
for _, p in ipairs(Players:GetPlayers()) do
	if p ~= Player then
		p.CharacterAdded:Connect(function()
			task.wait(0.5)
			RemoveEspForPlayer(p)
			CreateEspForPlayer(p)
		end)
	end
end

-- ========================
-- LOCK-ON LOGIC
-- ========================
local function GetNearestPlayerToCrosshair()
	local Character = Player.Character
	if not Character then return nil end
	local Humanoid = Character:FindFirstChildOfClass("Humanoid")
	if not Humanoid or Humanoid.Health <= 0 then return nil end

	local Center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	local Closest, ClosestDist = nil, math.huge

	for _, OtherPlayer in ipairs(Players:GetPlayers()) do
		if OtherPlayer == Player then continue end
		local OtherChar = OtherPlayer.Character
		if not OtherChar then continue end
		local OtherHum = OtherChar:FindFirstChildOfClass("Humanoid")
		if not OtherHum or OtherHum.Health <= 0 then continue end
		local Part = OtherChar:FindFirstChild(TargetPart)
		if not Part then continue end
		local ScreenPos, OnScreen = Camera:WorldToScreenPoint(Part.Position)
		if not OnScreen then continue end
		local Dist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - Center).Magnitude
		if Dist <= FovRadius and Dist < ClosestDist then
			ClosestDist = Dist
			Closest = OtherChar
		end
	end

	return Closest
end

UserInputService.InputBegan:Connect(function(Input, Processed)
	if Processed then return end
	if Input.UserInputType == Enum.UserInputType.MouseButton2 then
		if not Enabled then return end
		if CurrentTarget then
			CurrentTarget = nil
			FovStroke.Color = Color3.fromRGB(100,220,100)
		else
			CurrentTarget = GetNearestPlayerToCrosshair()
			if CurrentTarget then
				FovStroke.Color = Color3.fromRGB(220,60,60)
			end
		end
	end
end)

-- ========================
-- RENDER LOOP
-- ========================
RunService.RenderStepped:Connect(function()
	-- Lock-on camera
	if Enabled and CurrentTarget then
		local Hum = CurrentTarget:FindFirstChildOfClass("Humanoid")
		if not Hum or Hum.Health <= 0 then
			CurrentTarget = nil
			FovStroke.Color = Color3.fromRGB(100,220,100)
		else
			local Part = CurrentTarget:FindFirstChild(TargetPart)
			if Part then
				Camera.CFrame = Camera.CFrame:Lerp(
					CFrame.lookAt(Camera.CFrame.Position, Part.Position),
					Smoothness
				)
			end
		end
	end

	-- ESP per player
	for _, OtherPlayer in ipairs(Players:GetPlayers()) do
		if OtherPlayer == Player then continue end

		local obj = EspObjects[OtherPlayer.UserId]
		if not obj then continue end

		local Root = obj.Character and obj.Character:FindFirstChild("HumanoidRootPart")
		local Hum  = obj.HumanoidRef

		-- Distance check
		local LocalChar = Player.Character
		local LocalRoot = LocalChar and LocalChar:FindFirstChild("HumanoidRootPart")
		local InRange = false

		if Root and LocalRoot then
			InRange = (Root.Position - LocalRoot.Position).Magnitude <= EspDistance
		end

		local ShowEsp    = EspEnabled and InRange
		local ShowHitbox = ShowEsp and HitboxEnabled
		local ShowHealth = ShowEsp and HealthBarEnabled

		obj.Billboard.Enabled = ShowEsp
		obj.Hitbox.Enabled    = ShowHitbox
		obj.HealthBG.Enabled  = ShowHealth

		-- Update health bar fill
		if ShowHealth and Hum then
			local Pct = math.clamp(Hum.Health / Hum.MaxHealth, 0, 1)
			obj.HealthFill.Size = UDim2.new(1, 0, Pct, 0)
			-- Colour shifts green → red as health drops
			obj.HealthFill.BackgroundColor3 = Color3.fromRGB(
				math.floor(220 * (1-Pct)),
				math.floor(220 * Pct),
				0
			)
		end
	end
end)
